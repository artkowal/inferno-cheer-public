---
import Layout from '../layouts/Layout.astro';
import { Gallery } from '../components/Gallery';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/gallery/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}',
  { eager: true }
);

function altFromFilename(path: string): string {
  return path
    .split('/').pop()!
    .replace(/\.[^.]+$/, '')
    .replace(/[-_]/g, ' ')
    .replace(/^\w/, c => c.toUpperCase());
}

const images = await Promise.all(
  Object.entries(imageModules).map(async ([path, mod]) => {
    const src = mod.default;
    const [thumb, full] = await Promise.all([
      getImage({ src, width: 600, format: 'webp', quality: 80 }),
      getImage({ src, width: 1400, format: 'webp', quality: 85 }),
    ]);
    return {
      thumb: thumb.src,
      full: full.src,
      alt: altFromFilename(path),
    };
  })
);
---

<Layout
  title="Galeria | Inferno Cheer Elite"
  description="Galeria zdjęć Inferno Cheer Elite – zdjęcia z treningów, zawodów i wydarzeń szkoły cheerleadingu i tańca w Tarnowie."
>
  <main id="main-content" class="bg-background py-16 px-4">
    <div class="container mx-auto max-w-7xl">

      <div class="mb-12">
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-brand-500">Wspomnienia</p>
        <h1 class="font-spartan font-bold tracking-tight text-4xl lg:text-5xl text-foreground">
          Galeria Zdjęć
        </h1>
      </div>

      <Gallery images={images} client:load />

    </div>
  </main>
</Layout>

<style is:global>
  dialog.gallery-lightbox {
    width: 100vw;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    outline: none;
  }

  dialog.gallery-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.92);
  }
</style>
